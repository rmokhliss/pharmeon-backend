generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int             @id @default(autoincrement())
  reference   String          @unique
  nom         String
  marque      String
  categorie   String
  prix_achat  Float
  prix_vente  Float
  unite       String          @default("Pièce")
  stock       Int             @default(0)
  stock_min   Int             @default(5)
  description String?
  actif       Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  mouvements  StockMovement[]
}

model StockMovement {
  id            Int          @id @default(autoincrement())
  type          String
  quantite      Int
  note          String?
  productId     Int
  product       Product      @relation(fields: [productId], references: [id])
  clientId      Int?
  client        Client?      @relation(fields: [clientId], references: [id])
  fournisseurId Int?
  fournisseur   Fournisseur? @relation(fields: [fournisseurId], references: [id])
  createdAt     DateTime     @default(now())
}

model Client {
  id         Int             @id @default(autoincrement())
  nom        String
  type       String          @default("PARTICULIER")
  telephone  String?
  ville      String?
  adresse    String?
  actif      Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  sorties    StockMovement[]
}

model Fournisseur {
  id         Int             @id @default(autoincrement())
  nom        String
  contact    String?
  telephone  String?
  ville      String?
  actif      Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  entrees    StockMovement[]
}
