generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int             @id @default(autoincrement())
  reference   String          @unique
  nom         String
  marque      String
  categorie   String
  prix_achat  Float
  prix_vente  Float
  unite       String          @default("Pièce")
  stock       Int             @default(0)
  stock_min   Int             @default(5)
  description String?
  image_url   String?
  actif       Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  mouvements  StockMovement[]
  commandeItems CommandeItem[]
}

model StockMovement {
  id            Int          @id @default(autoincrement())
  type          String
  quantite      Int
  note          String?
  productId     Int
  product       Product      @relation(fields: [productId], references: [id])
  clientId      Int?
  client        Client?      @relation(fields: [clientId], references: [id])
  fournisseurId Int?
  fournisseur   Fournisseur? @relation(fields: [fournisseurId], references: [id])
  createdAt     DateTime     @default(now())
}

model Client {
  id         Int             @id @default(autoincrement())
  nom        String
  type       String          @default("PARTICULIER")
  telephone  String?
  ville      String?
  adresse    String?
  email      String?         @unique
  password   String?
  actif      Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  sorties    StockMovement[]
  commandes  Commande[]
}

model Commande {
  id         Int            @id @default(autoincrement())
  reference  String         @unique
  statut     String         @default("EN_ATTENTE")
  note       String?
  clientId   Int
  client     Client         @relation(fields: [clientId], references: [id])
  items      CommandeItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model CommandeItem {
  id           Int      @id @default(autoincrement())
  commandeId   Int
  commande     Commande @relation(fields: [commandeId], references: [id])
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  quantite     Int
  prixUnitaire Float
}

model Fournisseur {
  id         Int             @id @default(autoincrement())
  nom        String
  contact    String?
  telephone  String?
  ville      String?
  actif      Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  entrees    StockMovement[]
}

model DemandeAcces {
  id         Int      @id @default(autoincrement())
  categorie  String
  nom        String
  type       String?
  ville      String?
  telephone  String?
  email      String
  contact    String?
  message    String?
  statut     String   @default("EN_ATTENTE")
  createdAt  DateTime @default(now())
}
